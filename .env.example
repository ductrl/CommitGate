# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit your actual key.

# Required for the AI reviewer
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: AI review timeout in seconds (default: 20).
# Lower = less waiting per commit, but findings may be cut off if the model runs long.
# COMMITGATE_AI_TIMEOUT=20
