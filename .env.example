# Copy this file to `.env` and fill in your key. `.env` is gitignored — never commit it.
# This file holds SECRETS ONLY. Behavior (provider, timeout, severity) lives in commitgate.yaml.

# API key for the AI reviewer. One key for whichever HTTP provider you set in
# commitgate.yaml (openai / gemini / deepseek / kimi / groq).
# Not needed for claude-cli / codex-cli / agy-cli (they use your local login).
# Free option: get a Groq key at https://console.groq.com
AI_KEY=your-api-key-here
